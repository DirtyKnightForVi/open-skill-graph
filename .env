# CORE SERVICE -----------------------------------------------------------------------------
# 环境配置文件
# 模型配置
ONLINE_BASE_URL="https://api.deepseek.com/v1"
ONLINE_API_KEY=""
ONLINE_MODEL_NAME="deepseek-chat"

# 压缩模型配置
LLM_MODEL_NAME_FOR_COMPRESS=Qwen3_5-35B-A3B-64K
LLM_TOKEN_FOR_COMPRESS=

# 工作路径
# WORKSPACE_PATH="/home/yangjy/桌面/Data Agent/Project/SkillScope/skill-scope"
# LOG_PATH = "${WORKSPACE_PATH}/logs"

# 技能缓存配置
SKILLS_CACHE_PATH="${WORKSPACE_PATH}/skill_cache"

# 技能相关路径配置
SKILLS_PATH = "${WORKSPACE_PATH}/Agent_Work_Dir/Skills"
SKILLS_CREATE_TEMPLATE = "${WORKSPACE_PATH}/Agent_Work_Dir/Skills/SkillTemplete"
# 文件相关路径配置
UPLOAD_PATH = "${WORKSPACE_PATH}/Agent_Work_Dir/Files/User_Files"
UPLOADED_SKILL_PATH="${WORKSPACE_PATH}/Agent_Work_Dir/Files/Uploaded_Skills"
DOWNLOAD_SKILL_PATH="${WORKSPACE_PATH}/Agent_Work_Dir/Files/Download_Skills"
# 流式响应分块大小
STREAM_CHUNK_SIZE = 128
MODEL_MAX_TOKENS = 4096
REACT_MAX_ITERS = 17

# Skill-creator 配置
SKILL_CREATOR_NAME = "skill-creator"

# 请求超时配置
REQUEST_TIMEOUT_SECONDS=30


IF_SANDBOX = 1
SANDBOX_TYPE="skill_scope"
# 上下文压缩阈值
COMPRESS_LIMIT=45

# 行内的云端技能元信息查询地址
SKILL_META_API_URL=http://your-metadata-service:8080

# SANDBOX SERVICE ----------------------------------------------------------------------------
SANDBOX_SERVICE_URL=http://127.0.0.1:8000